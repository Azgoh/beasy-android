<?xml version="1.0" encoding="utf-8"?>
<!--
    input_bg.xml — The rounded rectangle background for each input field.
    This creates the light grey box with rounded corners and a subtle border.

    WHERE: Place this in app/src/main/res/drawable/input_bg.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Light grey fill -->
    <solid android:color="@color/input_bg" />

    <!-- Subtle border around the field -->
    <stroke
        android:width="1dp"
        android:color="@color/input_border" />

    <!-- Rounded corners — matching the screenshot's soft look -->
    <corners android:radius="10dp" />
</shape>